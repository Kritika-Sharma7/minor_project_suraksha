# ── App ──────────────────────────────────────────────
APP_ENV=development
APP_PORT=8000
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ── Database ─────────────────────────────────────────
DB_PATH=suraksha.db

# ── Twilio SMS ───────────────────────────────────────
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=your_twilio_phone_number
ALERT_TO_NUMBER=recipient_phone_number
ALERT_SMS_SENDER_NAME=Suraksha AI

# ── SMTP Email ───────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your_app_password
ALERT_EMAIL_TO=emergency@example.com

# ── Route APIs ───────────────────────────────────────
ROUTE_API_PROVIDER=mapbox          # mapbox | google
MAPBOX_TOKEN=pk.eyJ1...
GOOGLE_MAPS_KEY=AIza...
MAPS_LIVE_URL_TEMPLATE=https://maps.google.com/?q={lat},{lon}

# ── Alert queue ──────────────────────────────────────
SMS_MAX_OFFLINE_QUEUE=20
OFFLINE_QUEUE_FLUSH_INTERVAL_S=30

# ── Thresholds ───────────────────────────────────────
WARNING_THRESHOLD=70.0
DANGER_THRESHOLD=40.0
ROUTE_DEVIATION_METERS=200.0
ROUTE_DEVIATION_CONSECUTIVE_FRAMES=3
STOP_SPEED_THRESHOLD=1.0
STOP_TIME_THRESHOLD=180
JERK_THRESHOLD=8.0
FALL_SPIKE_THRESHOLD=25.0
FALL_QUIET_THRESHOLD=2.0
FALL_QUIET_FRAMES=2
FALL_WINDOW_S=5.0
AUDIO_KEYWORD_ENERGY_THRESHOLD=0.15
AUDIO_HIGH_ENERGY_THRESHOLD=0.25
AUDIO_ZCR_SPEECH_THRESHOLD=0.15
ELDER_INACTIVE_WARNING_S=300
ELDER_INACTIVE_DANGER_S=600

# ── WebSocket ────────────────────────────────────────
WS_HEARTBEAT_INTERVAL_S=25
WINDOW_SIZE=15
PERSISTENCE_FRAMES=3
ALERT_COOLDOWN_SECONDS=60
